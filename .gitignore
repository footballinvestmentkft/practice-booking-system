scripts/sql/cleanup/*.sql

# Local dev artifacts — never commit (PR-FC-1C scope cleanup)
qa_exports/
app/static/uploads/mood_photos/
app/static/uploads/lfa_player_photos/
scripts/dev_*.py
welcome-card-layout-validation.jsx
tests/snapshots/openapi_schema.json
tests/unit/test_card_preview_routing.py


# Biometric ONNX model weights — NEVER commit (PR-5 policy)
# Model files must be stored in an external artifact registry.
# See docs/biometric/PR5_PLAN.md for model weight policy.
*.onnx
app/services/biometric/models/

# Juggling dataset — large video files (licence_policy: never commit)
# Annotations and manifest are committed; videos are local/Seafile only.
datasets/juggling/videos/
app/uploads/juggling/*.mp4
app/uploads/juggling/*.mov
app/uploads/juggling/*_proc.mp4
app/uploads/juggling/*_thumb.jpg

# Juggling trained models — large binary files (licence_policy: never commit)
# Store in local_models/juggling/ locally; export path via config.
local_models/juggling/*.onnx
local_models/juggling/*.pt

# Biometric model weights — NEVER commit (GDPR + size policy)
# *.onnx.data: ONNX external data format (companion to *.onnx), up to 166 MB
# *.safetensors: HuggingFace model weights, up to 333 MB per model
# local_models/cvlface_*/: CVLFace model directories (weights + config)
# *.onnx already covered above; *.onnx.data is a separate extension.
*.onnx.data
*.safetensors
local_models/cvlface_*/

# Biometric test images — NEVER commit (GDPR: personal biometric data)
# Contains face photos of real individuals used for accuracy benchmarking.
scripts/test_images/

# Biometric uploads and profile photos — NEVER commit (GDPR: personal biometric data)
# biometric and profile images contain personal data (face photos of real individuals).
# none of these files may be committed.
app/uploads/biometric/
app/static/uploads/profile_photos/

# MediaPipe task model binaries — NEVER commit (generated/downloadable binaries)
# MediaPipe task models are generated/downloadable binaries; not source code.
# none of these files may be committed.
# Note: path-specific rule only — global *.task is intentionally avoided.
app/static/mediapipe/*.task

# Xcode per-developer data — editor state, breakpoints, layout (never shared)
xcuserdata/

# Xcode simulator build cache — generated output, not source
# Confirmed contents: Debug-iphoneos, ExplicitPrecompiledModules,
# LFAEducationCenter.build, XCBuildData (all build artefacts)
ios/ios/
local_models/juggling/*.pth

.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build Outputs
build/
dist/
*.tgz
*.tar.gz


# ============================================================================
# Practice Booking System — Environment Configuration Template
# ============================================================================
# Copy this file to `.env` and fill in the actual values.
# Never commit `.env` to version control — it contains secrets!

# ── API Configuration ───────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
API_TIMEOUT=30

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lfa_intern_system

# ── Cache & Background Jobs ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Background Removal (Mood Photos Phase 2) ────────────────────────────────
# "null"  → NullProcessor: Remove Background button hidden (safe default for Phase 1)
# "rembg" → RembgProcessor: real u2net background removal (requires Celery worker +
#            rembg==2.0.75 + onnxruntime>=1.19.0; u2net.onnx ~176 MB downloaded on first use)
# App:    BG_REMOVAL_PROCESSOR=rembg uvicorn app.main:app --reload --port 8000
# Worker: BG_REMOVAL_PROCESSOR=rembg celery -A app.celery_app worker -Q mood_photos -c 1 -l info
BG_REMOVAL_PROCESSOR=rembg

# ── E2E Testing ─────────────────────────────────────────────────────────────
# Base URLs for Playwright/Selenium tests
BASE_URL=http://localhost:8501     # Streamlit app
API_URL=http://localhost:8000      # FastAPI backend

# Optional: Specific test environment URLs
# CHAMPION_TEST_URL=http://localhost:8501

# ── Security ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32 OR python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<generate_with_openssl_rand_hex_32>

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=false

# ── CORS Configuration ──────────────────────────────────────────────────────
# Value MUST be a JSON array (pydantic-settings parses list[str] as JSON).
# Development/test: NOT required — get_cors_origins() returns localhost list
#   automatically when ENVIRONMENT=development|test. Leave commented out.
# Production: REQUIRED. Use JSON array format (bracket-wrapped, quoted URLs):
#   CORS_ALLOWED_ORIGINS=["https://app.lfa.com","https://admin.lfa.com"]
# WRONG (will crash on startup): CORS_ALLOWED_ORIGINS=http://localhost:3000
# WRONG (will crash on startup): CORS_ALLOWED_ORIGINS=https://a.com,https://b.com
# CORS_ALLOWED_ORIGINS=["https://app.example.com","https://admin.example.com"]

# ── Session & Cookies ───────────────────────────────────────────────────────
# Cookie security settings (auto-configured based on ENVIRONMENT)
# In production, cookies require HTTPS (COOKIE_SECURE=true)
# COOKIE_SECURE=false
# COOKIE_SAMESITE=strict
# COOKIE_HTTPONLY=true

# ── Database Connection Resilience ──────────────────────────────────────────
# DB_CONNECT_TIMEOUT    — seconds to wait for each connection attempt (default 10)
# DB_STATEMENT_TIMEOUT_MS — per-statement limit in ms, 0=disabled (default 0)
# DB_STARTUP_RETRIES    — retries before wait_for_db() aborts (default 5)
# DB_STARTUP_RETRY_DELAY — initial backoff in seconds, multiplied per attempt (default 2.0)
# DB_CONNECT_TIMEOUT=10
# DB_STATEMENT_TIMEOUT_MS=30000
# DB_STARTUP_RETRIES=5
# DB_STARTUP_RETRY_DELAY=2.0

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_DIR=logs
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5

# ── Slow Query Monitoring ────────────────────────────────────────────────────
# SLOW_QUERY_THRESHOLD_MS=200.0

# ── Alert Thresholds (GET /metrics/alerts) ───────────────────────────────────
# ALERT_REWARD_FAILURE_RATE=0.05
# ALERT_BOOKING_WAITLIST_RATE=0.30
# ALERT_ENROLLMENT_GATE_BLOCK_RATE=0.20
# ALERT_SLOW_QUERY_TOTAL=10

# ── Rate Limiting ───────────────────────────────────────────────────────────
ENABLE_RATE_LIMITING=false
LOGIN_RATE_LIMIT_CALLS=1000

# ── Admin User (Initial Setup) ──────────────────────────────────────────────
ADMIN_EMAIL=admin@lfa.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Administrator

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
#
# 1. ✅ Generate SECRET_KEY:
#    openssl rand -hex 32
#
# 2. ✅ Set strong ADMIN_PASSWORD (20+ chars, random)
#
# 3. ✅ Set CORS_ALLOWED_ORIGINS to HTTPS domains only (NO localhost!)
#
# 4. ✅ Set ENVIRONMENT=production
#
# 5. ✅ Deploy behind HTTPS reverse proxy (nginx, Caddy)
#
# 6. ✅ Set DATABASE_URL to production PostgreSQL instance
#
# 7. ✅ Set REDIS_URL to production Redis instance

// Config.Debug.xcconfig — Debug build backend URL
//
// SETUP (required before building to a physical iPhone):
//   1. Find your Mac's current LAN IP:
//      Terminal: ifconfig | grep "inet " | grep -v 127.0.0.1
//   2. Replace CHANGEME below with that IP. Example:
//      API_BASE_URL = http:$(SLASH)$(SLASH)192.168.1.129:8000
//
// Simulator builds:
//   API_BASE_URL = http:$(SLASH)$(SLASH)localhost:8000
//
// IMPORTANT: xcconfig files treat // as a comment delimiter — do NOT write
// http:// literally. Use SLASH = / so $(SLASH)$(SLASH) expands to // at
// build time. The SLASH variable is defined in this file.
//
// This file MUST NOT be committed with a real LAN IP — each developer
// sets this to their own Mac's IP. Add it to .gitignore if needed.
//
// The app will crash at launch with a clear message if this value is
// unexpanded or unreachable — that is intentional.

SLASH = /

// ── Local backend (Mac LAN) ──
// API_BASE_URL = http:$(SLASH)$(SLASH)192.168.1.129:8000

// ── Vercel staging (public HTTPS — works over cellular + GoPro Wi-Fi) ──
API_BASE_URL = https:$(SLASH)$(SLASH)practice-booking-system-git-deploy-vercel-staging-lfa-ec-test.vercel.app
